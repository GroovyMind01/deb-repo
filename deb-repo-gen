#!/usr/bin/env python3
"""
deb-repo-gen — Generate a Debian/Ubuntu APT repository from a directory tree
of .deb packages.

Features:
  - Recursive .deb scanning from one or more input directories
  - Automatic metadata extraction via dpkg-deb
  - Multi-distribution / multi-component / multi-architecture support
  - Full APT repository metadata: Packages, Packages.gz, Release, InRelease, Release.gpg
  - Optional GPG signing
  - Fully offline / air-gapped operation
  - Incremental updates — only processes changed packages
  - Idempotent — multiple runs with same inputs produce identical results
  - Duplicate and conflict detection
  - Corrupted .deb handling (skip + log, never abort)
  - Dry-run, verbose, and debug modes
  - Resumability after interruption
  - Built-in repository consistency validation
  - Primary backend: apt-ftparchive (from apt-utils)
  - Fallback backend: pure Python manual generation (zero extra deps)
  - Strict error handling, meaningful exit codes
  - ShellCheck-compliant style is not applicable (Python), but pylint-clean
"""

from __future__ import annotations

